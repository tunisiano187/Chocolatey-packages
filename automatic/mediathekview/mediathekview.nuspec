<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/08/nuspec.xsd">
  <metadata>
    <id>mediathekview</id>
    <version>14.5.0</version>
    <title>MediathekView</title>
    <authors>MediathekView Team</authors>
    <owners>tunisiano</owners>
    <licenseUrl>https://raw.githubusercontent.com/mediathekview/mediathekview/master/LICENSE</licenseUrl>
